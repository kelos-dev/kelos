#!/usr/bin/env bash
# Git credential helper backed by cody-tools. Invoked by git as
# `<helper> get` with the credential request on stdin.
set -euo pipefail

if [[ "${1:-}" != "get" ]]; then
  exit 0
fi

protocol=""
host=""
path=""
while IFS= read -r line; do
  [[ -z "$line" ]] && break
  case "$line" in
  protocol=*) protocol="${line#protocol=}" ;;
  host=*) host="${line#host=}" ;;
  path=*) path="${line#path=}" ;;
  esac
done

# Match the previous helper's behavior: only answer for GitHub HTTPS hosts.
if [[ "$protocol" != "https" ]]; then
  exit 0
fi
if [[ "$host" != "github.com" && "$host" != "api.github.com" ]]; then
  exit 0
fi

: "${CODY_TOOLS_GITHUB_BASE_URL:?CODY_TOOLS_GITHUB_BASE_URL is required}"

base_url="${CODY_TOOLS_GITHUB_BASE_URL%/}"
payload=$(jq -cn \
  --arg protocol "$protocol" \
  --arg host "$host" \
  --arg path "$path" \
  '{protocol:$protocol,host:$host,path:$path}')

response=$(curl -fsSL \
  --connect-timeout 5 \
  --max-time 10 \
  -X POST \
  -H "Accept: application/json" \
  -H "Content-Type: application/json" \
  --data "$payload" \
  "${base_url}/credential")

username=$(printf '%s' "$response" | jq -r '.username // ""')
password=$(printf '%s' "$response" | jq -r '.password // ""')
if [[ -z "$username" || -z "$password" ]]; then
  exit 0
fi

printf 'username=%s\npassword=%s\n\n' "$username" "$password"

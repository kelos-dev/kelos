#!/usr/bin/env bash
# npm wrapper: requests a fresh GitHub App installation token from cody-tools
# and exports it as NODE_AUTH_TOKEN before exec'ing the real npm binary.
#
# Sits at /usr/local/bin/npm, which is ahead of /usr/bin/npm in PATH, so
# any `npm` invocation (from the agent, from shells, from hooks) picks up
# GitHub Packages auth for the @quantum-wealth scope without per-call
# plumbing. Repos like notification-service ship a .npmrc that reads
# `_authToken=${NODE_AUTH_TOKEN}` against npm.pkg.github.com, so `npm ci`
# Just Works once the wrapper has populated the env.
#
# If NODE_AUTH_TOKEN is already set (operator override, CI injection), the
# wrapper does nothing — the existing token wins and real npm sees it
# unchanged.
#
# Requires the github-app to have `packages: read` enabled on the
# installation. Without that the minted token returns 401 against the
# npm registry; the App's installation token endpoint will still succeed,
# so the failure surfaces as an `npm ERR! 401 Unauthorized` on first
# install, not at token mint time.
set -euo pipefail

if [[ -z "${NODE_AUTH_TOKEN:-}" ]]; then
  NODE_AUTH_TOKEN=$(/usr/local/bin/cody-github-token --purpose npm)
  export NODE_AUTH_TOKEN
fi

exec /usr/bin/npm "$@"
